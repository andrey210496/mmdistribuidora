# ============================================================
# MM Retaguarda — exemplo de .env para a instalacao LOCAL (offline/LAN)
# Copie para a raiz do projeto como ".env" e ajuste os valores.
# O setup.ps1 faz essa copia automaticamente na 1a vez.
# ============================================================

# --- Banco de dados (PostgreSQL local desta maquina) ---
# Troque USUARIO/SENHA pelos do seu PostgreSQL. O banco "mm_distribuidora"
# e criado pelo "prisma db push" se ainda nao existir.
DATABASE_URL="postgresql://postgres:SUA_SENHA@localhost:5432/mm_distribuidora?schema=public"

# --- Sessao (login do admin) ---
# Gere uma chave aleatoria longa (>= 32 caracteres). NUNCA reutilize a de exemplo.
# Dica p/ gerar: no PowerShell ->  [guid]::NewGuid().ToString() + [guid]::NewGuid().ToString()
SESSION_SECRET="TROQUE_POR_UMA_CHAVE_ALEATORIA_LONGA_32+caracteres"

# --- Usuario admin inicial (criado pelo "npm run admin:ensure") ---
ADMIN_NAME="Administrador"
ADMIN_EMAIL="admin@mmdistribuidora.local"
ADMIN_PASSWORD="TROQUE_ESTA_SENHA"

# --- Uploads (imagens de produto etc.) ---
# Pasta local onde os arquivos enviados ficam guardados.
UPLOAD_DIR="./uploads"

# --- Ambiente ---
NODE_ENV="production"

# --- Sincronizacao com a vitrine online (opcional) ---
# Deixe SYNC_REMOTE_URL vazio enquanto nao houver loja online. Quando tiver,
# coloque a URL da vitrine e configure o MESMO SYNC_TOKEN nas duas pontas.
SYNC_TOKEN=""
SYNC_REMOTE_URL=""
