# ============================================================
# Doce Encanto - Variáveis de Ambiente
# ============================================================
# IMPORTANTE: copie este arquivo para .env e preencha os valores.
# NUNCA commite o .env real. Esse .env.example é o único versionado.
# ============================================================

# ---------- App ----------
NODE_ENV=development
APP_URL=http://localhost:3000
APP_NAME="Doce Encanto"

# ---------- Banco ----------
# Em dev local com docker-compose: postgresql://doce:doce@localhost:5432/doce_encanto
DATABASE_URL="postgresql://doce:doce@localhost:5432/doce_encanto"

# ---------- Sessão / Auth ----------
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Mínimo 32 caracteres. Troque em produção.
SESSION_SECRET="troque-isto-por-32-bytes-aleatorios-gerados-com-crypto-randomBytes"
SESSION_COOKIE_NAME="doce_session"

# ---------- Asaas (preencher quando a cliente fornecer) ----------
ASAAS_API_KEY=""
ASAAS_BASE_URL="https://sandbox.asaas.com/api/v3"
# Token compartilhado para validar autenticidade do webhook (definido no painel do Asaas)
ASAAS_WEBHOOK_TOKEN=""

# ---------- E-mail (opcional - para notificações de pedido) ----------
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Doce Encanto <nao-responda@doceencanto.com.br>"

# ---------- Segurança ----------
# Limite de requests por minuto por IP em rotas sensíveis
RATE_LIMIT_LOGIN_PER_MIN=5
RATE_LIMIT_CHECKOUT_PER_MIN=10

# ---------- NF-e (placeholder para integração futura) ----------
# Quando a cliente fornecer credenciais (Focus NFe / NFe.io), preencher aqui.
NFE_PROVIDER="manual"
NFE_API_KEY=""
NFE_API_URL=""
